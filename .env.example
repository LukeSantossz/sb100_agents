# ============================================================================
# SmartB100 — Arquivo de Configuração
# ============================================================================
# Copie este arquivo para .env e ajuste os valores conforme seu ambiente.
# Consulte SETUP.md para instruções detalhadas de configuração.
# ============================================================================

# ============================================================================
# MODO LOCAL (Qdrant via Docker)
# ============================================================================
# Use estas configurações para executar com Qdrant local via Docker Compose.
# Comando: docker compose --profile infra up -d

QDRANT_URL=http://localhost:6333
# Nome da coleção no Qdrant (deve corresponder ao usado na indexação)
COLLECTION_NAME=archives_v2

# ============================================================================
# MODO REMOTO (Qdrant via ZeroTier) — COMENTADO POR PADRÃO
# ============================================================================
# Para usar o servidor Qdrant remoto compartilhado:
# 1. Instale e configure o ZeroTier (zerotier-cli join <NETWORK_ID>)
# 2. Solicite as credenciais ao Tech Lead
# 3. Descomente e configure as linhas abaixo

# QDRANT_URL=http://<REMOTE_HOST_ZEROTIER>:6333
# QDRANT_API_KEY=<SOLICITAR_AO_TECH_LEAD>

# ============================================================================
# MODELOS OLLAMA
# ============================================================================
# Modelo de chat (geração de respostas RAG).
# Opções: llama3.2:3b (default, leve), llama3.1:8b (mais recursos/qualidade)
CHAT_MODEL=llama3.2:3b

# Modelo de embeddings para vetorização e busca semântica.
# Dimensão: 768 vetores
EMBED_MODEL=nomic-embed-text

# ============================================================================
# CONFIGURAÇÕES DE BUSCA RAG
# ============================================================================
# Quantidade de trechos mais similares a recuperar na busca (top-k).
TOP_K=3

# Limiar de entropia semântica para detecção de alucinação (0.0-1.0).
# Valores menores = mais rigoroso
HALLUCINATION_THRESHOLD=0.5

# Habilita (true) ou desabilita (false) o fluxo de verificação de alucinações.
VERIFICATION_ENABLED=true

# Provedor de LLM para geração de amostras na verificação de alucinação.
# Opções: groq (default, rápido), ollama (local), openrouter
VERIFICATION_PROVIDER=groq

# Modelo específico para verificação. Vazio = usa default do provider:
#   groq: llama-3.1-8b-instant | ollama: llama3.2:3b | openrouter: google/gemma-4-31b-it
VERIFICATION_CHAT_MODEL=

# Número de amostras para cálculo de entropia semântica (default: 2).
ENTROPY_NUM_SAMPLES=2

# ============================================================================
# APIS EXTERNAS (Pipeline de Avaliação e Verificação)
# ============================================================================
# Chaves de API usadas pelo pipeline de avaliação em eval/.
# Deixe vazio se não for usar o pipeline de avaliação.

# Chave da API OpenAI
OPENAI_API_KEY=

# Chave da API Groq (verificação de alucinação + eval pipeline)
GROQ_API_KEY=

# Chave da API OpenRouter (verificação de alucinação + eval pipeline)
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ============================================================================
# AUTENTICAÇÃO JWT
# ============================================================================
# Chave secreta para assinatura de tokens JWT.
# IMPORTANTE: Gere uma chave única em produção!
# Sugestão: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=super-secret-key-replace-in-production
